############################################
# MapControl (local Node + browser)
############################################

# Server
PORT=5179

# Yandex Maps v3
# IMPORTANT: do not commit real keys in .env.local
YANDEX_MAPS_API_KEY=xxxxx
YANDEX_MAPS_LANG=ru_RU

# LLM (OpenAI-compatible)
# --- routerai.ru (current) ---
LLM_BASE_URL=https://routerai.ru/api/v1
LLM_API_KEY=xxxxxx
LLM_MODEL=qwen/qwen3.5-flash-02-23

# --- vsellm.ru (fallback, slow ~90s but correct) ---
# LLM_BASE_URL=https://api.vsellm.ru/v1
# LLM_API_KEY=xxxxxx
# LLM_MODEL=qwen/qwen3.5-flash
# Note: requires chat_template_kwargs:{enable_thinking:false} in payload (already set in server.js)

# Image processing
IMAGE_MAX_WIDTH=2048
IMAGE_WEBP_QUALITY=80

# Email (SMTP) — настройте под свой провайдер:
# Gmail:        SMTP_HOST=smtp.gmail.com     SMTP_PORT=465  SMTP_SECURE=true
# Заводская почта (zavodsvay.ru): настройки уточняйте у админа
# Yandex 360:   SMTP_HOST=smtp.yandex.ru     SMTP_PORT=465  SMTP_SECURE=true
# biz.mail.ru:  SMTP_HOST=smtp.mail.ru       SMTP_PORT=587  SMTP_SECURE=false (требует пароль приложения + 2FA)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_TO=
# MAIL_NOTIFY=  # опционально: второй получатель (личное уведомление)
